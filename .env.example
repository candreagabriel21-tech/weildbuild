# ═══════════════════════════════════════════════════════════
# WeildBuild Environment Variables
# ═══════════════════════════════════════════════════════════
# Copy these to your Render dashboard (Environment tab).
# The values below are EXAMPLES — replace with your real keys.

# ─── Database (Supabase) ───
# Required for login, games, friends, shop, etc.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-key-here

# ─── Local SQLite (optional, for Prisma migrations only) ───
DATABASE_URL=file:./db/custom.db

# ─── Backblaze B2 Storage (optional — for asset uploads) ───
B2_KEY_ID=your-b2-key-id
B2_APPLICATION_KEY=your-b2-application-key
B2_BUCKET_NAME=weildbuild
B2_ENDPOINT=s3.eu-central-003.backblazeb2.com

# ─── Security ───
ALLOWED_ORIGINS=*
HTTPS_ENFORCE=true

# ─── Runtime ───
NODE_ENV=production

# ─── Socket.IO Server (for real-time: multiplayer, friend requests, chat) ───
# URL of your Render-hosted socket.io server (see socket-server/README.md).
# For local dev, run the socket-server package separately on port 3003.
# For Vercel production, deploy socket-server/ to Render and set this to
# the Render URL (e.g. https://weildbuild-socket.onrender.com).
NEXT_PUBLIC_SOCKET_URL=http://localhost:3003
